# Power BI Embedded Reports URLs
# These should be PUBLIC Power BI report URLs (marked as "public" in Power BI settings)
# Format: https://app.powerbi.com/reportEmbed?reportId=<REPORT_ID>&config=<CONFIG>

# Stock Report - Inventory levels and availability
VITE_POWERBI_STOCK_REPORT=

# Consumption Report - Medicine usage trends  
VITE_POWERBI_CONSUMPTION_REPORT=

# Distribution Report - Distribution analysis
VITE_POWERBI_DISTRIBUTION_REPORT=

# Movements Report - Stock movements analysis
VITE_POWERBI_MOVEMENTS_REPORT=

# Inventory Report - Inventory levels and alerts
VITE_POWERBI_INVENTORY_REPORT=
